{
  "name": "stackblitz-docs",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tinacms build --skip-cloud-checks && vitepress build",
    "dev": "vitepress dev",
    "format": "prettier --write '**/*.{js,ts,css,scss}'",
    "serve": "vitepress serve",
    "start": "vitepress dev"
  },
  "dependencies": {
    "@stackblitz/sdk": "^1.9.0",
    "firebase": "^12.11.0",
    "tinacms": "^3.7.1"
  },
  "devDependencies": {
    "@tinacms/cli": "^2.2.1",
    "@types/node": "^20.19.39",
    "@vue/tsconfig": "^0.5.1",
    "dotenv": "^16.4.5",
    "markdown-it-footnote": "^3.0.3",
    "prettier": "^3.2.5",
    "sass": "^1.72.0",
    "vitepress": "^1.6.4"
  },
  "prettier": {
    "printWidth": 100,
    "semi": true,
    "singleQuote": true,
    "useTabs": false
  }
}
