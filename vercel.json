{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "framework": null,
  "routes": [
    { "handle": "filesystem" },

    { "src": "^/admin$", "dest": "/admin/index.html" },
    { "src": "^/admin/", "dest": "/admin/index.html" },

    { "src": "^/blog/.*", "dest": "/blog/index.html" },

    { "src": "/.*", "dest": "/index.html" }
  ]
}
